# -------------------------------------------------------------
# Whale AI Environment Configuration
# -------------------------------------------------------------

# Use Gemini API instead of default NVIDIA API (Optional, defaults to false)
# Set to "true" to enable Gemini model, otherwise it defaults to NVIDIA NIM API.
GEMINI="false"

# Gemini API Key (Required if GEMINI="true")
# You can get a free API key from Google AI Studio:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_api_key_here"

# Application URL (Optional for local development)
# This is used for OAuth or self-referential links in production.
APP_URL="http://localhost:3000"
